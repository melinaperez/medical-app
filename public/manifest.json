{
  "id": "com.prescriptionseeding.app.v1",
  "name": "Prescription Seeding",
  "short_name": "PrescriptionSeeding",
  "description": "Aplicación para cálculo de riesgo cardiovascular",
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "dir": "ltr",
  "lang": "es-419",
  "scope": "/",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#ffffff",
  "theme_color": "#ffffff",
  "orientation": "portrait",
  "categories": ["medical", "healthcare"],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"],
    "route_mode": "navigate"
  },
  "scope_extensions": [
    {
      "origin": "https://prescriptionseeding.com"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "prescriptionseeding",
      "url": "/protocol?action=%s"
    },
    {
      "protocol": "medapp",
      "url": "/protocol?data=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "reports",
          "accept": ["application/pdf", ".pdf", "text/csv", ".csv"]
        }
      ]
    }
  },
