  "shortcuts": [
    {
      "name": "Nuevo Paciente",
      "short_name": "Nuevo",
      "url": "/medical-form",
      "description": "Crear nuevo registro de paciente",
      "icons": [
        {
          "src": "/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "url": "/dashboard",
      "description": "Ver dashboard de pacientes",
      "icons": [
        {
          "src": "/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "prefer_related_applications": false
}

